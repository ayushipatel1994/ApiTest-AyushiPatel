    {
      "name": "Add Product with Invalid Quantity",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 201 (API accepted request)\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Quantity should not be negative - business rule validation\", function () {",
              "    pm.expect(jsonData.products[0].quantity).to.be.above(0);",
              "});"
