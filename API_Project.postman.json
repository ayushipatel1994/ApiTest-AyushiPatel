    {
      "name": "Add Product to Cart (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has cart id\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.exist;",
              "});",
              "",
              "pm.test(\"Product quantity is correct\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.products[0].quantity).to.eql(5);",
              "});",
              "",
              "pm.test(\"Response contains products array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.products).to.be.an(\"array\");",
              "});",
              "",
              "const schema = {",
              "  type: 'object',",
              "  required: ['id', 'products'],",
              "  properties: {",
              "    id: { type: ['integer','number'] },",
              "    products: {",
              "      type: 'array',",
              "      items: {",
              "        type: 'object',",
              "        required: ['id', 'quantity'],",
              "        properties: {",
              "          id: { type: ['integer','number'] },",
              "          quantity: { type: ['integer','number'], minimum: 1 }",
              "        }",
              "      }",
              "    }",
              "  }",
              "};",
              "",
              "pm.collectionVariables.set('cartSchema', JSON.stringify(schema));",
              "",
              "pm.test('Response matches schema', function () {",
              "  pm.response.to.have.jsonSchema(JSON.parse(pm.collectionVariables.get('cartSchema')));",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
